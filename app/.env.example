# Copy this file to `.env` (or `.env.local`) and fill in your keys.
# Vite exposes vars prefixed with VITE_ to the browser at build/dev time.
# Both keys are optional — the game runs without them using a hardcoded
# spell pool and a "no transcript" fallback that scores as a fizzle.

VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
